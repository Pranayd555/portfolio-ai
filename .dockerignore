yarn-debug.log
yarn-error.log

# Local build distributions (prevents overwriting the container's compilation output)
dist/
out-tsc/
build/

# Debug and configuration files
.env
.env.local
.env.development
.env.production
.git
.gitignore
.project
.vscode/
.idea/
.codex/
.cursor/
.gemini/
.zed/

# Operating System metadata files
.DS_Store
Thumbs.db

